.progress-bar-container {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  background: #ffffff;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #e9e9e9;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #636e72;
  flex-shrink: 0;
}