.test-card {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.08);
}

.test-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #e9e9e9;
  flex-shrink: 0;
}

.test-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.test-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.test-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  margin-right: 16rpx;
}

.test-tag {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  border-radius: 20rpx;
}

.test-tag.tag-mental {
  color: #00b894;
  background: rgba(0, 184, 148, 0.1);
}

.test-tag.tag-fun {
  color: #f39c12;
  background: rgba(243, 156, 18, 0.1);
}

.test-desc {
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.test-footer {
  display: flex;
  margin-top: 16rpx;
}

.test-meta {
  display: flex;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  font-size: 24rpx;
  color: #b2bec3;
}

.meta-item image {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}