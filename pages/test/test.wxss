.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 180rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
}

.back-btn,
.save-btn {
  padding: 10rpx 20rpx;
}

.back-arrow {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 500;
}

.save-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

.progress-info {
  flex: 1;
  text-align: center;
}

.progress-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.progress-bar-wrapper {
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.question-content {
  padding: 40rpx;
}

.question-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.question-type-tag {
  display: inline-block;
  background: rgba(108, 92, 231, 0.1);
  color: #6C5CE7;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 34rpx;
  color: #2d3436;
  font-weight: 600;
  line-height: 1.6;
}

.options-simple {
  padding: 0 40rpx;
}

/* 单选题样式 */
.option-box {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #e9ecef;
  transition: all 0.3s ease;
}

.option-box.active {
  border-color: #6C5CE7;
  background: rgba(108, 92, 231, 0.05);
}

.option-box:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.option-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e9ecef;
  color: #636e72;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.option-box.active .option-circle {
  background: #6C5CE7;
  color: #ffffff;
}

.option-text-simple {
  flex: 1;
  margin-left: 24rpx;
  font-size: 30rpx;
  color: #2d3436;
  font-weight: 500;
  line-height: 1.5;
}

.option-checkmark {
  color: #6C5CE7;
  font-size: 40rpx;
  font-weight: bold;
}

/* 量表题样式 */
.scale-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.scale-button {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 3rpx solid #e9ecef;
  text-align: center;
  transition: all 0.3s ease;
}

.scale-button.active {
  border-color: #6C5CE7;
  background: rgba(108, 92, 231, 0.05);
}

.scale-button:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.scale-option-text {
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
}

.scale-button.active .scale-option-text {
  color: #6C5CE7;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.prev-btn,
.next-btn,
.submit-btn {
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.prev-btn {
  background: #e9ecef;
  color: #636e72;
}

.prev-btn.disabled {
  opacity: 0.4;
}

.next-btn {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
}

.submit-btn {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
  flex: 1;
  text-align: center;
  margin-left: 20rpx;
}