.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  padding-bottom: 160rpx;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #ffffff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
}

.back-btn image {
  width: 36rpx;
  height: 36rpx;
}

.progress-info {
  flex: 1;
  text-align: center;
}

.progress-text {
  font-size: 28rpx;
  color: #636e72;
}

.save-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  border-radius: 50rpx;
}

.progress-bar-wrapper {
  padding: 0 40rpx;
  background: #ffffff;
  padding-bottom: 30rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e9e9e9;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.question-content {
  padding: 40rpx;
}

.question-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.1);
}

.question-type-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  border-radius: 50rpx;
  margin-bottom: 24rpx;
}

.question-text {
  display: block;
  font-size: 32rpx;
  color: #2d3436;
  line-height: 1.8;
  font-weight: 500;
}

.options-list {
  padding: 0 40rpx;
}

.option-item {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.selected {
  border-color: #6C5CE7;
  background: rgba(108, 92, 231, 0.05);
}

.option-indicator {
  position: relative;
  width: 60rpx;
  flex-shrink: 0;
}

.option-letter {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  color: #636e72;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 50%;
}

.option-item.selected .option-letter {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
}

.option-check {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: #6C5CE7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-check image {
  width: 24rpx;
  height: 24rpx;
}

.option-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.option-text {
  font-size: 28rpx;
  color: #2d3436;
  line-height: 1.6;
}

.scale-options {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
}

.scale-item {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
  font-size: 28rpx;
  color: #636e72;
}

.scale-item.selected {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.prev-btn,
.next-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #f0f0f0;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #636e72;
}

.prev-btn.disabled {
  opacity: 0.5;
}

.prev-btn image,
.next-btn image {
  width: 32rpx;
  height: 32rpx;
  margin: 0 8rpx;
}

.next-btn {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
}

.submit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #00b894 0%, #55efc4 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 50rpx;
  margin-left: 30rpx;
}