<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="onBackTap">
      <image src="/images/icon-back.png" mode="aspectFit"></image>
    </view>
    <view class="progress-info">
      <text class="progress-text">第{{currentIndex + 1}}题 / 共{{totalCount}}题</text>
    </view>
    <view class="save-btn" bindtap="onSaveExit">
      <text>保存退出</text>
    </view>
  </view>

  <view class="progress-bar-wrapper">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <view class="question-content">
    <view class="question-card">
      <view class="question-type-tag">
        <text wx:if="{{question.type === 1}}">单选题</text>
        <text wx:if="{{question.type === 2}}">多选题</text>
        <text wx:if="{{question.type === 3}}">量表题</text>
      </view>
      <text class="question-text">{{question.content}}</text>
    </view>
  </view>

  <view class="options-list">
    <view
      class="option-item {{selectedOptionId === option.id ? 'selected' : ''}}"
      wx:for="{{question.options}}"
      wx:key="id"
      bindtap="onOptionTap"
      data-id="{{option.id}}"
      data-index="{{index}}"
    >
      <view class="option-indicator">
        <view class="option-letter">{{letters[index]}}</view>
        <view class="option-check" wx:if="{{selectedOptionId === option.id}}">
          <image src="/images/icon-check.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="option-content">
        <text class="option-text">{{option.content}}</text>
        <view class="scale-options" wx:if="{{question.type === 3}}">
          <view class="scale-item {{selectedScale === idx ? 'selected' : ''}}" wx:for="{{[1,2,3,4,5]}}" wx:for-index="idx" wx:key="idx" bindtap="onScaleTap" data-scale="{{idx}}">
            <text>{{idx + 1}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="prev-btn {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="onPrevTap">
      <image src="/images/icon-arrow-left.png" mode="aspectFit"></image>
      <text>上一题</text>
    </view>
    <view class="next-btn" bindtap="onNextTap" wx:if="{{currentIndex < totalCount - 1}}">
      <text>下一题</text>
      <image src="/images/icon-arrow-right.png" mode="aspectFit"></image>
    </view>
    <view class="submit-btn" bindtap="onSubmitTap" wx:if="{{currentIndex === totalCount - 1}}">
      <text>提交答案</text>
    </view>
  </view>
</view>