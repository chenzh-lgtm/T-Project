<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="back-btn" bindtap="onBackTap">
      <text class="back-arrow">←</text>
    </view>
    <view class="progress-info">
      <text class="progress-text">第{{currentIndex + 1}}题 / 共{{totalCount}}题</text>
    </view>
    <view class="save-btn" bindtap="onSaveExit">
      <text>保存退出</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar-wrapper">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <!-- 题目内容 -->
  <view class="question-content">
    <view class="question-card">
      <view class="question-type-tag">
        <text>{{getTypeText(question.type)}}</text>
      </view>
      <text class="question-text">{{question.content}}</text>
    </view>
  </view>

  <!-- 选项区域 -->
  <view class="options-simple">
    <!-- 单选题 -->
    <view
      wx:for="{{question.options}}"
      wx:key="id"
      wx:if="{{question.type !== 3}}"
      class="option-box {{selectedOptionId === item.id ? 'active' : ''}}"
      bindtap="onOptionTap"
      data-id="{{item.id}}"
    >
      <view class="option-circle">{{letters[index]}}</view>
      <view class="option-text-simple">{{item.content}}</view>
      <view class="option-checkmark" wx:if="{{selectedOptionId === item.id}}">✓</view>
    </view>

    <!-- 量表题 -->
    <view class="scale-wrapper" wx:if="{{question.type === 3}}">
      <view
        wx:for="{{question.options}}"
        wx:for-index="index"
        wx:key="id"
        class="scale-button {{selectedScale === index ? 'active' : ''}}"
        bindtap="onScaleTap"
        data-index="{{index}}"
        data-id="{{item.id}}"
      >
        <text class="scale-option-text">{{item.content}}</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="prev-btn {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="onPrevTap">
      <text>上一题</text>
    </view>
    <view class="next-btn" bindtap="onNextTap" wx:if="{{currentIndex < totalCount - 1}}">
      <text>下一题</text>
    </view>
    <view class="submit-btn" bindtap="onSubmitTap" wx:if="{{currentIndex === totalCount - 1}}">
      <text>提交答案</text>
    </view>
  </view>
</view>