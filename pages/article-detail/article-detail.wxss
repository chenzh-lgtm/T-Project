.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.article-header {
  background: #ffffff;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.article-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.article-category {
  font-size: 24rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.article-reads {
  font-size: 24rpx;
  color: #b2bec3;
}

.article-content {
  background: #ffffff;
  padding: 40rpx 30rpx;
  margin: 0 20rpx 30rpx;
  border-radius: 16rpx;
}

.content-text {
  display: block;
  font-size: 30rpx;
  color: #2d3436;
  line-height: 1.8;
  white-space: pre-wrap;
}

.article-footer {
  padding: 0 30rpx;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #6C5CE7, #a29bfe);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #b2bec3;
}
