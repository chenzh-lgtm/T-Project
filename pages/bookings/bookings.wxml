<view class="container">
  <view wx:if="{{bookings.length === 0}}" class="empty-state">
    <text class="empty-icon">📅</text>
    <text class="empty-text">暂无预约记录</text>
    <text class="empty-hint">去预约一位心理咨询师吧</text>
    <button class="go-btn" bindtap="goToConsult">去预约</button>
  </view>

  <view wx:else class="booking-list">
    <view wx:for="{{bookings}}" wx:key="id" class="booking-card">
      <view class="booking-header" bindtap="onBookingTap" data-id="{{item.id}}">
        <view class="counselor-info">
          <view class="counselor-avatar">{{item.counselorAvatar}}</view>
          <view class="counselor-detail">
            <text class="counselor-name">{{item.counselorName}}</text>
            <view class="booking-time">
              <text class="date">{{item.date}}</text>
              <text class="divider">·</text>
              <text class="time">{{item.time}}</text>
            </view>
          </view>
        </view>
        <view class="booking-status {{item.status}}">
          {{item.status === 'pending' ? '待咨询' : item.status === 'completed' ? '已完成' : '已取消'}}
        </view>
      </view>
      <view class="booking-body" bindtap="onBookingTap" data-id="{{item.id}}">
        <view class="location">
          <text class="location-icon">📍</text>
          <text class="location-text">{{item.location}}</text>
        </view>
      </view>
      <view class="booking-footer">
        <button 
          wx:if="{{item.status === 'pending'}}" 
          class="cancel-btn" 
          bindtap="cancelBooking" 
          data-id="{{item.id}}"
        >
          取消预约
        </button>
        <button 
          wx:if="{{item.status === 'pending'}}" 
          class="complete-btn" 
          bindtap="onBookingTap"
          data-id="{{item.id}}"
        >
          完成咨询
        </button>
        <button 
          wx:if="{{item.status === 'completed' && !item.rating}}" 
          class="review-btn" 
          bindtap="onBookingTap"
          data-id="{{item.id}}"
        >
          评价
        </button>
        <text wx:if="{{item.status === 'completed' && item.rating}}" class="review-done">已评价</text>
      </view>
    </view>
  </view>
</view>