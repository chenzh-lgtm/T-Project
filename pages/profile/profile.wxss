.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 50rpx;
}

.profile-header {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  padding: 60rpx 40rpx 80rpx;
}

.user-info-section {
  display: flex;
  align-items: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: #e9e9e9;
}

.user-detail {
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: -40rpx 40rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #6C5CE7;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #636e72;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e9e9e9;
}

.menu-section {
  margin: 30rpx 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2d3436;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
}

.menu-arrow image {
  width: 100%;
  height: 100%;
}