.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.loading-view {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
}

.empty-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
  text-align: center;
}

.start-btn {
  background-color: #6C5CE7;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.collection-list {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.collection-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.collection-item:last-child {
  border-bottom: none;
}

.collection-item:active {
  background-color: #f9f9f9;
}

.collection-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 15rpx;
  margin-right: 25rpx;
  background-color: #f0f0f0;
}

.collection-info {
  flex: 1;
}

.collection-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.collection-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.collection-meta {
  display: flex;
  align-items: center;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
}

.meta-divider {
  color: #ddd;
  margin: 0 10rpx;
}

.collection-action {
  padding-left: 20rpx;
}

.collected-icon {
  font-size: 36rpx;
}

.collected-icon:active {
  transform: scale(0.9);
}