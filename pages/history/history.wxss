.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.loading-view {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
}

.empty-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.start-btn {
  background-color: #6C5CE7;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.history-list {
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background-color: #f9f9f9;
}

.history-header {
  flex: 1;
}

.test-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.test-date {
  font-size: 24rpx;
  color: #999;
}

.history-content {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}

.result-badge {
  background-color: #6C5CE7;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.result-badge.score {
  background-color: #00b894;
}

.result-type {
  color: white;
  font-size: 24rpx;
  font-weight: 500;
}

.history-arrow {
  color: #ccc;
  font-size: 28rpx;
}

.clear-section {
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: center;
}

.clear-btn {
  background-color: white;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.clear-btn::after {
  border: none;
}