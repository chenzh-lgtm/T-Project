<view class="container">
  <view class="search-bar">
    <view class="search-input-wrapper">
      <image class="search-icon" src="/images/icon-search.png" mode="aspectFit"></image>
      <input
        class="search-input"
        type="text"
        placeholder="搜索测试名称..."
        value="{{searchKey}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <view class="clear-btn" bindtap="onClearSearch" wx:if="{{searchKey}}">
        <image src="/images/icon-clear.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="category-tabs">
    <view
      class="tab-item {{currentCategoryId === 0 ? 'active' : ''}}"
      bindtap="onTabChange"
      data-id="0"
    >
      <text>全部</text>
    </view>
    <view
      class="tab-item {{currentCategoryId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onTabChange"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="test-list">
    <view
      class="test-card"
      wx:for="{{filteredTests}}"
      wx:key="id"
      bindtap="onTestTap"
      data-id="{{item.id}}"
    >
      <image class="test-cover" src="{{item.coverImage}}" mode="aspectFill"></image>
      <view class="test-info">
        <view class="test-header">
          <text class="test-name">{{item.name}}</text>
          <view class="test-tag" wx:if="{{item.categoryId === 1}}">性格</view>
          <view class="test-tag tag-mental" wx:if="{{item.categoryId === 2}}">心理</view>
          <view class="test-tag tag-fun" wx:if="{{item.categoryId === 3}}">趣味</view>
        </view>
        <text class="test-desc">{{item.description}}</text>
        <view class="test-footer">
          <view class="test-meta">
            <view class="meta-item">
              <image src="/images/icon-question.png" mode="aspectFit"></image>
              <text>{{item.questionCount}}题</text>
            </view>
            <view class="meta-item">
              <image src="/images/icon-time.png" mode="aspectFit"></image>
              <text>{{item.estimatedTime}}分钟</text>
            </view>
          </view>
          <view class="start-btn">
            <text>开始测试</text>
            <image src="/images/arrow-right.png" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{filteredTests.length === 0}}">
    <image src="/images/empty-icon.png" mode="aspectFit"></image>
    <text>暂无相关测试</text>
  </view>
</view>