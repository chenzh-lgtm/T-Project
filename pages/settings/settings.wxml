<view class="container">

  <!-- 隐私设置 -->
  <view class="section">
    <view class="section-title">隐私设置</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="onPrivacyPolicy">
        <view class="setting-left">
          <text class="setting-icon">📋</text>
          <text class="setting-text">隐私政策</text>
        </view>
        <view class="setting-arrow">
          <text>→</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onUserAgreement">
        <view class="setting-left">
          <text class="setting-icon">📝</text>
          <text class="setting-text">用户协议</text>
        </view>
        <view class="setting-arrow">
          <text>→</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onDataExport">
        <view class="setting-left">
          <text class="setting-icon">📤</text>
          <text class="setting-text">导出数据</text>
        </view>
        <view class="setting-arrow">
          <text>→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 其他设置 -->
  <view class="section">
    <view class="section-title">其他</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="onCheckUpdate">
        <view class="setting-left">
          <text class="setting-icon">🔄</text>
          <text class="setting-text">检查更新</text>
        </view>
        <view class="setting-right">
          <text class="version-text">v1.0.0</text>
          <text class="setting-arrow">→</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onClearCache">
        <view class="setting-left">
          <text class="setting-icon">🗑️</text>
          <text class="setting-text">清理缓存</text>
        </view>
        <view class="setting-right">
          <text class="cache-size">{{cacheSize}}</text>
          <text class="setting-arrow">→</text>
        </view>
      </view>
    </view>
  </view>

</view>