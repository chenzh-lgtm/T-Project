.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #6C5CE7 0%, #a29bfe 100%);
  padding-bottom: 200rpx;
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.result-badge {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.result-badge image {
  width: 100%;
  height: 100%;
}

.result-type {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.result-card {
  margin: 0 40rpx;
  background: #ffffff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.result-score-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(108, 92, 231, 0.3);
}

.score-inner {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #6C5CE7;
}

.score-label {
  font-size: 24rpx;
  color: #b2bec3;
  margin-top: 8rpx;
}

.result-title-wrapper {
  text-align: center;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3436;
  line-height: 1.5;
}

.result-section {
  margin: 30rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.section-icon image {
  width: 100%;
  height: 100%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.section-content {
  padding-left: 64rpx;
}

.analysis-text,
.suggestion-text {
  font-size: 28rpx;
  color: #636e72;
  line-height: 1.8;
}

.notice-content {
  background: rgba(108, 92, 231, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-left: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #6C5CE7;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.action-btn image {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 8rpx;
}

.action-btn text {
  font-size: 22rpx;
  color: #636e72;
}

.retry-btn image {
  width: 44rpx;
  height: 44rpx;
}

.share-btn {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
}

.share-btn image {
  width: 44rpx;
  height: 44rpx;
}

.share-btn text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.share-btn {
  flex-direction: row;
  gap: 10rpx;
}