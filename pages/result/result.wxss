.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #6C5CE7 0%, #a29bfe 100%);
  padding-bottom: 380rpx;
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.result-badge {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-emoji {
  font-size: 80rpx;
}

.result-type {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.mbti-card {
  margin: 0 40rpx;
  background: #ffffff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.mbti-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.mbti-type-big {
  font-size: 100rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
}

.mbti-name-big {
  font-size: 36rpx;
  color: #6C5CE7;
  margin-top: 16rpx;
  font-weight: 600;
}

.mbti-intro {
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.intro-text {
  font-size: 30rpx;
  color: #2d3436;
  line-height: 1.6;
  font-weight: 500;
}

.personality-card {
  margin: 0 40rpx;
  background: #ffffff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.personality-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.personality-emoji {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.personality-type {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #e17055 0%, #fdcb6e 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.personality-name {
  font-size: 36rpx;
  color: #e17055;
  font-weight: 600;
}

.personality-intro {
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.personality-title {
  font-size: 30rpx;
  color: #2d3436;
  line-height: 1.6;
  font-weight: 500;
}

.phq-card {
  margin: 0 40rpx;
  background: #ffffff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.phq-score-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00b894 0%, #55efc4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 184, 148, 0.3);
  margin-bottom: 30rpx;
}

.score-inner {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 60rpx;
  font-weight: 700;
  color: #00b894;
}

.score-label {
  font-size: 24rpx;
  color: #b2bec3;
  margin-top: 8rpx;
}

.phq-result-text {
  text-align: center;
}

.phq-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  line-height: 1.5;
}

.result-section {
  margin: 30rpx 40rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.section-content {
  padding-left: 0;
}

.strengths-wrapper,
.careers-wrapper {
  margin-bottom: 20rpx;
}

.strengths-wrapper:last-child,
.careers-wrapper:last-child {
  margin-bottom: 0;
}

.strengths-text,
.careers-text,
.analysis-text,
.suggestion-text,
.advice-text {
  display: block;
  font-size: 28rpx;
  color: #636e72;
  line-height: 1.8;
}

.notice-content {
  background: rgba(108, 92, 231, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-left: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #6C5CE7;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 200rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-radius: 30rpx 30rpx 0 0;
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
  width: 140rpx;
}

.btn-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-btn text {
  font-size: 22rpx;
  color: #636e72;
}

.retry-btn {
  background: #f8f9fa;
}

.save-btn {
  background: #6C5CE7;
}

.save-btn text {
  color: #ffffff;
}

.share-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

.share-title {
  font-size: 24rpx;
  color: #636e72;
  text-align: center;
  margin-bottom: 16rpx;
}

.share-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.share-btn-wechat,
.share-btn-timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 40rpx;
  border-radius: 16rpx;
  border: none;
  margin: 0;
  min-width: 140rpx;
}

.share-btn-wechat::after,
.share-btn-timeline::after {
  border: none;
}

.share-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.share-text {
  font-size: 22rpx;
  color: #ffffff;
}

.share-btn-wechat {
  background: #07c160;
}

.share-btn-timeline {
  background: #ff6b6b;
}

.action-bottom {
  height: 100rpx;
}

.scl90-factors {
  padding: 10rpx 0;
}

.factor-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.factor-item:last-child {
  margin-bottom: 0;
}

.factor-name {
  width: 160rpx;
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
}

.factor-score-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.factor-score {
  width: 60rpx;
  font-size: 28rpx;
  color: #6C5CE7;
  font-weight: 600;
  text-align: right;
}

.scl90-summary {
  padding: 10rpx 0;
}

.summary-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-item:last-child {
  margin-bottom: 0;
}

.summary-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
}

.summary-value {
  font-size: 32rpx;
  color: #6C5CE7;
  font-weight: 700;
  margin-right: 12rpx;
}

.summary-unit {
  font-size: 24rpx;
  color: #636e72;
}