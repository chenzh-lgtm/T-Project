page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.container {
  padding: 20rpx;
}

.counselor-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.counselor-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-right: 24rpx;
}

.counselor-basic {
  flex: 1;
  color: #fff;
}

.counselor-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.counselor-title {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 12rpx;
}

.counselor-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.star {
  font-size: 28rpx;
}

.rating-value {
  font-size: 28rpx;
  font-weight: bold;
}

.divider {
  color: rgba(255, 255, 255, 0.5);
  margin: 0 12rpx;
}

.consult-count {
  font-size: 24rpx;
  opacity: 0.8;
}

.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-card {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.booking-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.date-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.date-list {
  display: inline-flex;
  gap: 16rpx;
}

.date-item {
  display: inline-flex;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.date-item.active {
  background-color: #667eea;
  color: #fff;
}

.time-section {
  margin-bottom: 24rpx;
}

.time-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-item {
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.time-item.selected {
  background-color: #667eea;
  color: #fff;
}

.location-section {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 26rpx;
  color: #667eea;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 2rpx solid #eee;
}

.booking-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.booking-btn:active {
  opacity: 0.8;
}