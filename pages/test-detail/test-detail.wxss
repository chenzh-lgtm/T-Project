.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 140rpx;
}

.test-cover-wrapper {
  position: relative;
  height: 400rpx;
}

.test-cover {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.test-emoji {
  font-size: 120rpx;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.test-category {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(108, 92, 231, 0.8);
  border-radius: 50rpx;
}

.test-content {
  padding: 40rpx;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: -40rpx;
  position: relative;
}

.test-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.test-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #2d3436;
  flex: 1;
  padding-right: 80rpx;
}

.collect-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
  transition: all 0.2s;
}

.collect-emoji {
  font-size: 40rpx;
}

.collect-btn.collected {
  background: rgba(108, 92, 231, 0.1);
}

.test-meta {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-right: 50rpx;
  font-size: 26rpx;
  color: #636e72;
}

.meta-emoji {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.test-desc-section {
  padding: 30rpx 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 16rpx;
}

.test-desc {
  display: block;
  font-size: 28rpx;
  color: #636e72;
  line-height: 1.8;
}

.test-guide-section {
  padding: 30rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.guide-list {
  margin-top: 24rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.guide-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  flex-shrink: 0;
}

.guide-content {
  margin-left: 20rpx;
  flex: 1;
}

.guide-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3436;
  margin-bottom: 8rpx;
}

.guide-desc {
  display: block;
  font-size: 24rpx;
  color: #636e72;
}

.notice-section {
  display: flex;
  padding: 30rpx;
  background: rgba(108, 92, 231, 0.05);
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.notice-emoji {
  font-size: 48rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #6C5CE7;
  margin-bottom: 8rpx;
}

.notice-desc {
  display: block;
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 40rpx;
  margin-right: 30rpx;
}

.share-emoji {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.share-btn text {
  font-size: 22rpx;
  color: #636e72;
}

.start-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 50rpx;
  transition: transform 0.2s;
}

.start-btn:active {
  transform: scale(0.98);
}