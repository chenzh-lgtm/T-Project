page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.booking-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

.counselor-info {
  display: flex;
  align-items: center;
}

.counselor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
}

.counselor-detail {
  color: #fff;
}

.counselor-name {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.booking-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.booking-status.pending {
  background-color: rgba(255, 193, 7, 0.3);
  color: #ffc107;
}

.booking-status.completed {
  background-color: rgba(40, 167, 69, 0.3);
  color: #28a745;
}

.booking-status.cancelled {
  background-color: rgba(108, 117, 125, 0.3);
  color: #6c757d;
}

.card-body {
  padding: 30rpx;
}

.info-section {
  margin-bottom: 30rpx;
}

.info-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.time-info {
  display: flex;
  gap: 20rpx;
}

.date, .time {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.location-text {
  font-size: 30rpx;
  color: #333;
}

.create-time {
  font-size: 28rpx;
  color: #666;
}

.card-footer {
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.action-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.action-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.action-btn.review {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.review-result {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.review-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.review-stars {
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.review-comment {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.review-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.review-content {
  width: 90%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.review-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.review-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.rating-section {
  margin-bottom: 30rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 20rpx;
}

.rating-star {
  font-size: 48rpx;
  color: #ccc;
  transition: all 0.3s;
}

.rating-star.selected {
  color: #FFD700;
}

.comment-section {
  margin-bottom: 30rpx;
}

.comment-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}